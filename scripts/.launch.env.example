# Configuration for scripts/launch_and_tunnel.sh and scripts/first_time_setup.sh
#
# Copy this file to scripts/.launch.env and customize.
#   cp scripts/.launch.env.example scripts/.launch.env
#
# Tip: variables exported in your shell before running the scripts override
# values in this file for one-off runs.

# MN5 (BSC) host routing:
# - Job submission + tunneling: alogin1-4.bsc.es
# - Local<->cluster data transfers: transfer1.bsc.es
# - Internet downloads (e.g. uv sync): alogin4.bsc.es
REMOTE_LAUNCH_HOST="alogin1.bsc.es"
REMOTE_TRANSFER_HOST="transfer1.bsc.es"
REMOTE_INTERNET_HOST="alogin4.bsc.es"

# Required: your BSC login username.
# Used for ssh, rsync, and the default remote checkout path under /home/bsc/<REMOTE_USER>/.
REMOTE_USER="your_username"

# Optional: value exported as VEC_INF_STORAGE_USER for path templates in
# vec_inf/config/marenostrum5/models.yaml or environment.yaml.
# Most users can leave this empty unless those templates intentionally use a
# different name than REMOTE_USER.
VEC_INF_STORAGE_USER=""

# Default model name if not provided on CLI
MODEL_NAME="Llama-3.2-3B-Instruct"

# Local port to bind the tunnel on
LOCAL_PORT=5678

# If LOCAL_PORT is already used by an existing matching ssh tunnel, kill it.
# Safe default is 0.
AUTO_KILL_STALE_TUNNEL=0

# Set to 1 to rsync this local checkout to MN5 before first setup / launch.
# Recommended for normal usage so the remote copy matches your local repo.
RSYNC_ENABLED=0
# Local directory to sync to MN5. Usually leave as "." from the repo root.
RSYNC_SRC="."
# Remote repository checkout path on MN5.
# This is where rsync copies the repo and where first_time_setup.sh runs `uv sync`.
# If empty, the scripts default to /home/bsc/<REMOTE_USER>/repos/vector-inference.
# Recommended for fresh clone / side-by-side versions:
#   RSYNC_DEST="/home/bsc/<REMOTE_USER>/repos/vector-inference-mn5"
RSYNC_DEST=""

# Python environment on the remote login node used to run `vec-inf launch`.
# first_time_setup.sh creates this when it runs `uv sync` in RSYNC_DEST.
# If empty, the launcher defaults to ${RSYNC_DEST}/.venv.
# Recommended explicit value:
#   VEC_INF_ENV="/home/bsc/<REMOTE_USER>/repos/vector-inference-mn5/.venv"
VEC_INF_ENV=""

# Remote directory containing the MN5-specific `environment.yaml` and `models.yaml`.
# The launcher exports this as VEC_INF_CONFIG_DIR before running vec-inf.
# Default points to the bundled MN5 profile inside RSYNC_DEST so the remote
# launch uses this checkout's MN5 config files.
# Set to NONE to disable exporting VEC_INF_CONFIG_DIR.
# Recommended explicit value:
#   VEC_INF_CONFIG_DIR_REMOTE="/home/bsc/<REMOTE_USER>/repos/vector-inference-mn5/vec_inf/config/marenostrum5"
VEC_INF_CONFIG_DIR_REMOTE=""

# Working directory passed to `vec-inf launch --work-dir` and used as SBATCH --chdir.
# This is where vec-inf keeps per-job caches like .vec-inf-cache during execution.
# Leave empty to use vec-inf / cluster defaults.
# To run jobs from the rsynced checkout, set:
#   REMOTE_WORK_DIR="RSYNC_DEST"
# Recommended isolated work dir inside the repo checkout:
#   REMOTE_WORK_DIR="/home/bsc/<REMOTE_USER>/repos/vector-inference-mn5"
REMOTE_WORK_DIR=""

# Recommended: Slurm account to charge the job to.
# The current MN5 team examples in this repo use bsc70 by default.
# The launcher passes this as --account so users do not need remote shell setup.
REMOTE_ACCOUNT=""

# Optional: QoS override passed as --qos.
# Leave empty to use the default already defined by the selected MN5 config.
# Set to NONE to force the script not to pass --qos at all.
REMOTE_QOS=""

# Extra flags forwarded to `uv sync` during first_time_setup.sh.
# `--frozen` is the safest default for reproducible installs from uv.lock.
UV_SYNC_ARGS="--frozen"

# Optional MN5 profile path overrides consumed by
# vec_inf/config/marenostrum5/environment.yaml.
# Default shared team image:
#   /gpfs/scratch/bsc70/singularity/vllm_openai_latest.sif
VEC_INF_VLLM_IMAGE_PATH=""
VEC_INF_CACHED_MODEL_CONFIG_PATH=""
VEC_INF_MODEL_WEIGHTS_PARENT_DIR=""

# Timeouts (seconds)
JOB_START_TIMEOUT=900
SERVER_READY_TIMEOUT=2000
